rules_version = '2';

// ============================================================
// FLOW Mega Apps — Firestore Security Rules (v3.9.6)
//
// DEPLOYMENT:
//   firebase deploy --only firestore:rules
//
// 🔑 PERMISSION MODEL:
//
//   ┌─────────────┬───────────┬───────────────────┬────────┬────────┐
//   │ Role        │ Read all  │ Create / Update   │ Delete │ /users │
//   ├─────────────┼───────────┼───────────────────┼────────┼────────┤
//   │ admin       │   ✅ ALL  │ ❌ (read-only)    │   ❌   │   ✅   │
//   │ supervisor  │   ✅ ALL  │ ✅ everything     │   ✅   │   ✅   │
//   │ user        │   ✅ ALL  │ only own records  │   ❌   │   ❌   │
//   └─────────────┴───────────┴───────────────────┴────────┴────────┘
//
//   - Admin: oversight role. Sees everything, can manage user accounts
//     (assign roles), but CANNOT edit or delete operational data.
//   - Supervisor: writes operational data AND manages users
//     (onboarding + password resets are supervisor-led — see v3.9.2).
//   - User: limited write — can create/update their own records only.
//
//   PRIVACY EXCEPTION: /one_on_ones contains sensitive HR data and
//   is NOT readable by all signed-in users — only supervisors, admins,
//   and the subject of the 1-on-1 (memberEmail == own email).
//
//   Roles live in /users/{userEmail}.role and are resolved on every
//   request. The legacy role names (sales-admin, ss-admin, sales, ss)
//   are kept as aliases.
//
// COLLECTIONS:
//   daily_issues, daily_tasks_sales, daily_tasks_ss, tickets,
//   revenue_scenarios, projections, clients, departments,
//   issue_categories, one_on_one_questions, one_on_ones,
//   audit_log, users
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ----- Helpers ---------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    // Role of the currently-signed-in user, looked up from
    // /users/{email}. Returns null if the user has no profile doc.
    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && userRole() in ['admin', 'sales-admin', 'ss-admin'];
    }

    function isSupervisor() {
      return isSignedIn() && userRole() in ['supervisor', 'sales', 'ss'];
    }

    function isLimitedUser() {
      return isSignedIn() && userRole() == 'user';
    }

    // True when the document is owned by the current user (createdBy
    // matches the signed-in email).
    function ownsDoc() {
      return isSignedIn()
        && resource != null
        && resource.data.createdBy == request.auth.token.email;
    }

    // True when the incoming document marks the current user as creator.
    function createsAsSelf() {
      return isSignedIn()
        && request.resource.data.createdBy == request.auth.token.email;
    }

    // ----- /users ----------------------------------------------------
    // Role assignments + production passwords (stored in Firebase Auth,
    // not here — this collection only carries the profile/role doc).
    // Both Admins and Supervisors can manage users; supervisors handle
    // day-to-day onboarding and password resets.
    // Every signed-in user can read their OWN doc (so the client can
    // resolve their role on login).
    match /users/{userEmail} {
      allow read:   if isSignedIn()
                     && (userEmail == request.auth.token.email || isAdmin() || isSupervisor());
      allow create: if isAdmin() || isSupervisor();
      allow update: if isAdmin() || isSupervisor();
      allow delete: if isAdmin() || isSupervisor();
    }

    // ----- Audit log — append-only ----------------------------------
    // Any signed-in user (including admin) can add audit entries so
    // master-data viewers can record "X viewed Y at time Z" if needed.
    // No updates, no deletes — preserve the audit trail.
    // The createdBy field must match the writer (no spoofing).
    match /audit_log/{docId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn()
                     && (!("createdBy" in request.resource.data)
                         || request.resource.data.createdBy == request.auth.token.email);
      allow update: if false;
      allow delete: if false;
    }

    // ----- /one_on_ones — sensitive HR data --------------------------
    // 1-on-1 sessions contain personal info (workload struggles,
    // mental-health flags, manager feedback). Unlike other collections,
    // read access is restricted: supervisors, admins, and the subject
    // of the session can read; everyone else is blocked.
    match /one_on_ones/{docId} {
      allow read:   if isSupervisor() || isAdmin()
                     || (isSignedIn() && resource.data.memberEmail == request.auth.token.email);
      allow create: if isSupervisor();
      allow update: if isSupervisor();
      allow delete: if isSupervisor();
    }

    // ----- Connection ping ------------------------------------------
    // Used by the app to verify Firestore connectivity on boot.
    match /_test/_connection {
      allow read:  if true;
      allow write: if false;
    }

    // ----- /daily_issues — required field validation ------------------
    // MBR reports depend on clean data. Enforce non-empty required
    // fields on create/update so issues can't be saved without the
    // minimum fields needed for reporting.
    function issueHasRequired() {
      return request.resource.data.client is string && request.resource.data.client.size() > 0
          && request.resource.data.complainDate is string && request.resource.data.complainDate.size() > 0
          && request.resource.data.categoriComplain is string && request.resource.data.categoriComplain.size() > 0
          && request.resource.data.updateBy is string && request.resource.data.updateBy.size() > 0;
    }

    match /daily_issues/{docId} {
      allow read: if isSignedIn();
      allow create: if (isSupervisor() || (isLimitedUser() && createsAsSelf()))
                     && issueHasRequired();
      allow update: if (isSupervisor()
                     || (isLimitedUser() && ownsDoc()
                         && request.resource.data.createdBy == resource.data.createdBy))
                     && issueHasRequired();
      allow delete: if isSupervisor();
    }

    // ----- All other collections ------------------------------------
    // Operational data: tasks, tickets, projections, master data, etc.
    match /{collection}/{docId} {
      // Read: every signed-in user can read.
      allow read: if isSignedIn();

      // Create:
      //   - Supervisor: always.
      //   - User: only if they mark themselves as createdBy.
      //   - Admin: NEVER (read-only).
      allow create: if isSupervisor()
                     || (isLimitedUser() && createsAsSelf());

      // Update:
      //   - Supervisor: always.
      //   - User: only their own records, AND createdBy must not change
      //     (otherwise a user could rewrite ownership and escape the
      //     ownsDoc check on future edits).
      //   - Admin: NEVER (read-only).
      allow update: if isSupervisor()
                     || (isLimitedUser() && ownsDoc()
                         && request.resource.data.createdBy == resource.data.createdBy);

      // Delete:
      //   - Supervisor: always.
      //   - User: NEVER (must ask a supervisor).
      //   - Admin: NEVER (read-only).
      allow delete: if isSupervisor();
    }
  }
}
